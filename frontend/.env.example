# Frontend environment variables for Vite

# VITE_API_URL: Backend API endpoint
# 
# Local development (npm run dev):
#   - Leave this unset to use window.location.origin (http://localhost:5173/api)
#   - Or set this to point to your backend (http://localhost:5000/api)
# 
# Production builds:
#   - Set via GitHub Actions workflow (see .github/workflows/)
#   - Current production backend: https://orpon-backend-api-sea.azurewebsites.net/api
#
# Uncomment and update for local backend development:
# VITE_API_URL=http://localhost:5000/api
