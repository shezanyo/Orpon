# ========================================
# Orpon Backend Configuration
# ========================================
# For local development: copy to .env and fill in actual values.
# For production: set these as Azure App Service Settings.
# DO NOT commit the actual .env file with real values!

# ========================================
# SERVER & PORT
# ========================================
PORT=5000

# ========================================
# ⚠️ CRITICAL: URLs for Payment Redirects
# ========================================
# These MUST match your deployed URLs exactly.
# Incorrect URLs will cause payment sandbox to fail.

# Your backend API URL (used for payment callbacks from gateways)
# Local development: http://localhost:5000
# Azure production: https://orpon-backend-api-sea.azurewebsites.net
BACKEND_URL=http://localhost:5000

# Your frontend SPA URL (used for redirecting users after payment)
# Local development: http://localhost:5173
# Azure production: https://thankful-sea-0f5fbd000.7.azurestaticapps.net
# UPDATE THIS after deploying frontend to Azure!
FRONTEND_URL=http://localhost:5173

# ========================================
# DATABASE (Azure SQL / MSSQL)
# ========================================
# For local MySQL: use localhost
# For Azure SQL: use orpon-sql-server.database.windows.net
DB_HOST=your-server.database.windows.net
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=donation_system
DB_PORT=1433
DB_TRUST_CERT=false

# ========================================
# REDIS (Optional – app falls back to in-memory)
# ========================================
USE_REDIS=false
REDIS_URL=redis://localhost:6379

# ========================================
# SECURITY
# ========================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_string

# ========================================
# CLOUDINARY
# ========================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ========================================
# bKash Sandbox
# ========================================
BKASH_USERNAME=your_bkash_sandbox_username
BKASH_PASSWORD=your_bkash_sandbox_password
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# ========================================
# SSLCommerz Sandbox
# ========================================
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_BASE_URL=https://sandbox.sslcommerz.com

# ========================================
# 🔍 AZURE DEPLOYMENT SETUP
# ========================================
# After deploying to Azure, update these settings in Azure Portal:
# > App Service > Configuration > Application settings
#
# Required updates:
# 1. BACKEND_URL = https://orpon-backend-api-sea.azurewebsites.net (your actual backend URL)
# 2. FRONTEND_URL = https://thankful-sea-0f5fbd000.7.azurestaticapps.net (your actual frontend URL)
# 3. DB_HOST = orpon-sql-server.database.windows.net
# 4. DB_TRUST_CERT = false (for Azure SQL)
#
# To update via CLI:
# az webapp config appsettings set \
#   --resource-group OrponRG \
#   --name orpon-backend-api \
#   --settings BACKEND_URL=https://your-backend-url FRONTEND_URL=https://your-frontend-url
#
# Troubleshooting:
# - Payment sandbox not working? Check BACKEND_URL and FRONTEND_URL are set
# - Database errors? Check firewall rules and DB credentials
# - Check logs: az webapp log tail --resource-group OrponRG --name orpon-backend-api
